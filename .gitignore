# GTFS raw data (large, downloaded on demand)
data/*/gtfs.zip
data/*/gtfs/

# Processed output (generated, not committed)
output/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.xcworkspace
*.xcodeproj
xcuserdata/
.vscode/

# Dependencies
node_modules/
.nuxt/
.output/
Pods/
build/

# Env
.env
.env.local
.env*.local

# Python
__pycache__/
*.pyc
.venv/

# Git worktrees
.worktrees/

# Claude / MCP tooling caches
.claude/
.playwright-mcp/

# UX review screenshot artifacts (local)
ux-review-*.png
.designer-eye-qa/

# Session-local audit/research prompts (not part of the codebase)
AUDIT_*_PROMPT.md
*_CROSSCHECK_PROMPT.md

# Secrets — NEVER commit
android/local.properties
android/app/src/main/res/values/secrets.xml
ios/TransitKit/Sources/Services/TransitKitSecrets.swift
*.keystore
*.jks

# Firebase per-operator config — bundle-restricted but kept out of git so
# each operator manages their own Firebase project independently.
shared/operators/*/firebase/GoogleService-Info.plist
shared/operators/*/firebase/google-services.json
# Build artifact: staged from shared/operators/<op>/firebase/google-services.json
# by scripts/build-android.sh
android/app/google-services.json
.vercel
